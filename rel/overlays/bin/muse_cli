#!/usr/bin/env sh
set -eu

# rel/overlays/bin/muse_cli — Convenience wrapper for the Muse Mix release.
#
# This script is placed at _build/prod/rel/muse/bin/muse_cli by the
# overlay mechanism declared in mix.exs.  It resolves its own directory
# at runtime and forwards all arguments to the release's bin/muse eval
# command, which in turn calls Muse.CLI.ReleaseCommand.main/1.
#
# Usage (from the release directory):
#   bin/muse_cli --tui --no-web
#   bin/muse_cli --repl
#   bin/muse_cli --help

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
exec "$SCRIPT_DIR/muse" eval "Muse.CLI.ReleaseCommand.main(System.argv())" -- "$@"
