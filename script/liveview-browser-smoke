#!/usr/bin/env bash
# script/liveview-browser-smoke
#
# Executable LiveView browser QA smoke test.
#
# Starts Muse with fake provider on a non-default port, waits for HTTP
# readiness, runs HTTP/HTML accessibility and discoverability assertions,
# and tears down cleanly. Non-interactive — suitable for CI and dev use.
#
# Usage:
#   ./script/liveview-browser-smoke
#   MUSE_BROWSER_SMOKE_PORT=4200 ./script/liveview-browser-smoke
#
# Environment:
#   MUSE_BROWSER_SMOKE_PORT    — HTTP port, 1..65535 and free (default: 4101)
#   MUSE_BROWSER_SMOKE_HOST    — Local HTTP host: 127.0.0.1, localhost, or 0.0.0.0 (default: 127.0.0.1)
#   MUSE_BROWSER_SMOKE_TIMEOUT — Positive readiness timeout in seconds (default: 60)
#
# Prerequisites:
#   - Elixir/Erlang installed
#   - curl installed
#   - mix deps.get has been run
#
# This script does NOT require a real browser (Playwright/QA Kitten).
# For browser console-error detection and keyboard focus verification,
# see script/liveview-browser-smoke-playwright or docs/testing.md §11.7.
#
# Exit codes:
#   0 — all smoke checks passed
#   1 — one or more smoke checks failed, or server failed to start

set -euo pipefail

cd "$(dirname "$0")/.."
ROOT="$(pwd)"

PORT="${MUSE_BROWSER_SMOKE_PORT:-4101}"
HOST="${MUSE_BROWSER_SMOKE_HOST:-127.0.0.1}"
TIMEOUT="${MUSE_BROWSER_SMOKE_TIMEOUT:-60}"
MUSE_PROVIDER="fake"
MIX_ENV="smoke"
BASE_URL=""

SERVER_PID=""
SMOKE_LOG=""
NORMALIZED_INTEGER=""

error() {
    echo "ERROR: $*" >&2
    exit 1
}

validate_positive_integer() {
    local name="$1"
    local value="$2"

    if ! [[ "${value}" =~ ^[0-9]+$ ]]; then
        error "invalid ${name} '${value}'; must be a positive integer"
    fi

    local normalized="${value}"
    while [[ "${normalized}" == 0* && "${normalized}" != "0" ]]; do
        normalized="${normalized#0}"
    done

    if [ "${normalized}" = "0" ]; then
        error "invalid ${name} '${value}'; must be a positive integer"
    fi

    if [ "${#normalized}" -gt 9 ]; then
        error "invalid ${name} '${value}'; must be a positive integer less than 1000000000"
    fi

    NORMALIZED_INTEGER="${normalized}"
}

validate_configuration() {
    validate_positive_integer "MUSE_BROWSER_SMOKE_PORT" "${PORT}"
    PORT="${NORMALIZED_INTEGER}"
    if [ "${PORT}" -gt 65535 ]; then
        error "invalid MUSE_BROWSER_SMOKE_PORT '${PORT}'; must be in 1..65535"
    fi

    validate_positive_integer "MUSE_BROWSER_SMOKE_TIMEOUT" "${TIMEOUT}"
    TIMEOUT="${NORMALIZED_INTEGER}"

    if [ -z "${HOST}" ]; then
        error "invalid MUSE_BROWSER_SMOKE_HOST; cannot be empty"
    fi

    if [[ "${HOST}" == *"://"* ]] || [[ "${HOST}" == *"/"* ]] || \
       [[ "${HOST}" == *"\\"* ]] || [[ "${HOST}" == *"@"* ]] || \
       [[ "${HOST}" == *":"* ]] || [[ "${HOST}" =~ [[:space:]] ]] || \
       [[ ! "${HOST}" =~ ^[A-Za-z0-9._-]+$ ]]; then
        error "invalid MUSE_BROWSER_SMOKE_HOST '${HOST}'; use a local host without scheme, port, or path"
    fi

    if [ "${HOST}" != "127.0.0.1" ] && [ "${HOST}" != "localhost" ] && \
       [ "${HOST}" != "0.0.0.0" ]; then
        error "invalid MUSE_BROWSER_SMOKE_HOST '${HOST}'; use 127.0.0.1, localhost, or 0.0.0.0"
    fi

    if ! command -v curl >/dev/null 2>&1; then
        error "curl is required for LiveView smoke readiness checks"
    fi

    BASE_URL="http://${HOST}:${PORT}"
}

http_ready() {
    curl --fail --silent --show-error \
        --connect-timeout 1 \
        --max-time 2 \
        --output /dev/null \
        "${BASE_URL}/" >/dev/null 2>&1
}

print_server_log() {
    if [ -n "${SMOKE_LOG:-}" ] && [ -f "${SMOKE_LOG}" ]; then
        echo "       Server log (last 80 lines):" >&2
        tail -80 "${SMOKE_LOG}" >&2 2>/dev/null || true
    else
        echo "       Server log unavailable." >&2
    fi
}

fail_if_server_exited() {
    local context="${1:-before readiness}"

    if [ -z "${SERVER_PID:-}" ] || kill -0 "${SERVER_PID}" 2>/dev/null; then
        return 0
    fi

    local status=0
    wait "${SERVER_PID}" 2>/dev/null || status=$?
    echo "ERROR: Muse server exited ${context} (status ${status})." >&2
    print_server_log
    exit 1
}

preflight_target_free() {
    if http_ready; then
        echo "ERROR: ${BASE_URL}/ already responds before this script launched Muse." >&2
        echo "       Stop the stale server or choose a free MUSE_BROWSER_SMOKE_PORT." >&2
        exit 1
    fi
}

cleanup() {
    if [ -n "${SERVER_PID:-}" ] && kill -0 "${SERVER_PID}" 2>/dev/null; then
        echo "==> Stopping Muse server (PID ${SERVER_PID})"
        kill "${SERVER_PID}" 2>/dev/null || true
        # Give the BEAM a few seconds to shut down gracefully
        local wait_count=0
        while kill -0 "${SERVER_PID}" 2>/dev/null && [ $wait_count -lt 5 ]; do
            sleep 1
            wait_count=$((wait_count + 1))
        done
        # Force kill if still alive
        if kill -0 "${SERVER_PID}" 2>/dev/null; then
            kill -9 "${SERVER_PID}" 2>/dev/null || true
        fi

        wait "${SERVER_PID}" 2>/dev/null || true
    fi
    # Clean up temp log file
    if [ -n "${SMOKE_LOG:-}" ] && [ -f "${SMOKE_LOG}" ]; then
        rm -f "${SMOKE_LOG}"
    fi
}
trap cleanup EXIT

validate_configuration

echo "==> Muse LiveView Browser Smoke"
echo "    URL:     ${BASE_URL}/"
echo "    Port:    ${PORT}"
echo "    Host:    ${HOST}"
echo "    Timeout: ${TIMEOUT}s"
echo "    Env:     ${MIX_ENV}"
echo "    Provider: ${MUSE_PROVIDER}"
echo ""

preflight_target_free

# Compile in the smoke environment first so readiness wait
# doesn't race with compilation.
echo "==> Compiling (MIX_ENV=${MIX_ENV})..."
MIX_ENV="${MIX_ENV}" mix compile 2>&1

# Start Muse server in background, capturing output to a temp log.
SMOKE_LOG="$(mktemp /tmp/muse-smoke-server.XXXXXX.log)"
echo "==> Starting Muse on ${BASE_URL}/ (fake provider)..."
MIX_ENV="${MIX_ENV}" MUSE_PROVIDER="${MUSE_PROVIDER}" \
    mix muse --web-only --host "${HOST}" --port "${PORT}" --no-watch \
    > "${SMOKE_LOG}" 2>&1 &
SERVER_PID=$!

# Wait for HTTP readiness
echo "==> Waiting for server readiness..."
start_seconds=${SECONDS}
deadline=$((start_seconds + TIMEOUT))
elapsed=0
ready=0
while [ "${SECONDS}" -lt "${deadline}" ]; do
    elapsed=$((SECONDS - start_seconds))
    fail_if_server_exited

    if http_ready; then
        fail_if_server_exited
        elapsed=$((SECONDS - start_seconds))
        echo "==> Server ready after ${elapsed}s"
        ready=1
        break
    fi

    sleep 1
done

if [ "${ready}" -ne 1 ]; then
    echo "ERROR: Muse did not become ready within ${TIMEOUT}s at ${BASE_URL}/" >&2
    print_server_log
    exit 1
fi

# Run smoke assertions via the Mix task.
echo "==> Running smoke assertions..."
fail_if_server_exited "before smoke assertions"
MIX_ENV="${MIX_ENV}" mix muse.smoke --port "${PORT}" --host "${HOST}"
fail_if_server_exited "during smoke assertions"

echo ""
echo "==> LiveView browser smoke complete!"
